# Teaming24 GUI Environment Variables
# ====================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# =============================================================================
# API Configuration
# =============================================================================

# API base URL - Backend server address
# Default: empty (uses same origin, works when frontend is served by backend)
# Set this when running frontend dev server separately from backend
VITE_API_BASE_URL=http://localhost:8000

# API prefix for all endpoints (usually don't need to change)
VITE_API_PREFIX=/api
